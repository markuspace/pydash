def write_file(path: str, content: str) -> str:
    """write_file with path, content"""
    import re
    content = re.sub(r'^```.*$\n?', '', content, flags=re.MULTILINE)
    content = content.strip()
    with open(path, "w") as f:
        f.write(content)
    return f"wrote {path}"

def run_command(cmd: str) -> str:
    """run_command with cmd"""
    import subprocess
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout + result.stderr

coder = {
    "system": "You are a C coder. You write working C programs. Use the tools available to you.",
    "model": "qwen3:8b",
    "tools": [write_file, run_command]
}

output = coder — "Write a hello, world program in C, save it to hello.c, compile it with gcc, and run it."
print(output["message"]["content"])
